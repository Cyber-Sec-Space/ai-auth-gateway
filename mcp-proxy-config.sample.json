{
  "system": {
    "port": 3000,
    "logLevel": "INFO",
    "pingIntervalMs": 60000,
    "pingTimeoutMs": 10000,
    "idleTimeoutMs": 300000,
    "reconnectTimeoutMs": 5000
  },
  "masterKey": "your_securely_generated_64_character_hex_string",
  "plugins": [
    {
      "name": "@cyber-sec.space/aag-core-rate-limit",
      "options": {
        "maxRequests": 50,
        "windowMs": 60000
      }
    },
    {
      "name": "@cyber-sec.space/aag-core-data-masking",
      "options": {
        "rules": [
          "(?i)(password|secret|token).{0,5}[:=].{0,5}['\"][^'\"]+['\"]"
        ],
        "maskString": "***[MASKED]***"
      }
    }
  ],
  "mcpServers": {
    "local_database": {
      "transport": "stdio",
      "command": "node",
      "args": [
        "/path/to/your/database_mcp.js"
      ],
      "authInjection": {
        "type": "none"
      }
    },
    "github_mcp": {
      "transport": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "authInjection": {
        "type": "header",
        "headerName": "Authorization",
        "value": "Bearer keytar://github/pat"
      }
    },
    "remote_service": {
      "transport": "sse",
      "url": "https://my-remote-service.com/sse",
      "authInjection": {
        "type": "env",
        "key": "API_KEY",
        "value": "$MY_ENV_API_KEY"
      }
    }
  },
  "aiKeys": {
    "example-ai": {
      "key": "your_securely_generated_ai_key_hash",
      "description": "An example AI client assigned specific tool access",
      "createdAt": "2026-03-25T00:00:00.000Z",
      "revoked": false,
      "permissions": {
        "allowedServers": [
          "local_database"
        ],
        "deniedServers": [],
        "allowedTools": [
          "github_mcp___get_me"
        ],
        "deniedTools": [
          "local_database___drop_table"
        ]
      }
    }
  }
}
